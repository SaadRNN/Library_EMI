<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.SignUpController">
    <children>
        <HBox prefHeight="600.0" prefWidth="900.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <AnchorPane prefHeight="600.0" prefWidth="350.0" style="-fx-background-color: #1a252f;">
                    <children>
                        <ImageView fitHeight="600.0" fitWidth="350.0" opacity="0.4" pickOnBounds="true" preserveRatio="false">
                            <image>
                                <Image url="@library_bg.jpg" />
                            </image>
                        </ImageView>
                        <VBox alignment="CENTER_LEFT" prefHeight="600.0" prefWidth="350.0" spacing="15.0" style="-fx-background-color: linear-gradient(to bottom, transparent, rgba(26, 37, 47, 0.9));">
                            <padding>
                                <Insets left="30.0" />
                            </padding>
                            <children>
                                <Label text="Rejoignez" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="36.0" />
                                    </font>
                                </Label>
                                <Label text="L'ÉLITE EMI" textFill="#007AFF">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <Line endX="80.0" opacity="0.6" stroke="WHITE" strokeWidth="2.0" />
                                <Label prefWidth="250.0" text="Créez votre compte pour accéder à des milliers de ressources académiques." textFill="#bdc3c7" wrapText="true">
                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>

                <VBox alignment="CENTER" prefHeight="600.0" prefWidth="550.0" spacing="20.0" style="-fx-background-color: white;">
                    <padding>
                        <Insets left="60.0" right="60.0" />
                    </padding>
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Inscription" textFill="#243447">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                                <Label text="Veuillez remplir vos informations." textFill="#94a3b8">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <GridPane hgap="15.0" vgap="15.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Prénom" textFill="#64748b" />
                                        <TextField fx:id="firstNameField" prefHeight="40.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" GridPane.columnIndex="1">
                                    <children>
                                        <Label text="Nom" textFill="#64748b" />
                                        <TextField fx:id="lastNameField" prefHeight="40.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                                    <children>
                                        <Label text="Email académique (@Student.emi.ac.ma)" textFill="#64748b" />
                                        <TextField fx:id="emailField" prefHeight="40.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" GridPane.rowIndex="2">
                                    <children>
                                        <Label text="Mot de passe" textFill="#64748b" />
                                        <PasswordField fx:id="passwordField" prefHeight="40.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                    <children>
                                        <Label text="Confirmation" textFill="#64748b" />
                                        <PasswordField fx:id="confirmPasswordField" prefHeight="40.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8;" />
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>

                        <Button fx:id="signUpButton" onAction="#handleSignUp" mnemonicParsing="false" prefHeight="45.0" prefWidth="430.0" style="-fx-background-color: #007AFF; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;" text="Créer mon compte">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                            <effect>
                                <DropShadow color="#007aff44" offsetY="5.0" radius="10.0" />
                            </effect>
                        </Button>
                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="Déjà inscrit ?" textFill="#94a3b8" />
                                <Hyperlink onAction="#switchToLogin" style="-fx-font-weight: bold;" text="Se connecter" textFill="#243447" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
