<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #F8FAFC;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ForgotPasswordController">
    <children>
        <HBox prefHeight="600.0" prefWidth="900.0"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- SIDEBAR -->
                <AnchorPane prefHeight="600.0" prefWidth="420.0" style="-fx-background-color: #1a252f;">
                    <children>
                        <ImageView fitHeight="600.0" fitWidth="420.0" opacity="0.4"
                                   pickOnBounds="true" preserveRatio="false">
                            <image><Image url="@library_bg.jpg" /></image>
                        </ImageView>
                        <VBox alignment="CENTER_LEFT" prefHeight="600.0" prefWidth="420.0"
                              spacing="15.0"
                              style="-fx-background-color: linear-gradient(to bottom, transparent, rgba(26, 37, 47, 0.8));">
                            <padding><Insets left="40.0" /></padding>
                            <children>
                                <Label text="EMIBook" textFill="WHITE">
                                    <font><Font name="System Bold" size="48.0" /></font>
                                    <effect><DropShadow radius="10.0" color="#00000055" /></effect>
                                </Label>
                                <Label text="MANAGEMENT SYSTEM V2.0" textFill="#007AFF">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <Line endX="100.0" stroke="WHITE" strokeWidth="2.0" opacity="0.6" />
                                <Label text="Nous allons vous aider à récupérer votre accès."
                                       textFill="#bdc3c7" wrapText="true" prefWidth="300.0">
                                    <font><Font size="14.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                        <Label text="© 2026 EMI ENGINEERING" textFill="#7f8c8d"
                               AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="40.0">
                            <font><Font size="10.0" /></font>
                        </Label>
                    </children>
                </AnchorPane>

                <!-- FORMULAIRE -->
                <VBox alignment="CENTER" prefHeight="600.0" prefWidth="480.0"
                      spacing="25.0" style="-fx-background-color: white;">
                    <padding><Insets left="70.0" right="70.0" /></padding>
                    <children>

                        <!-- Icône cadenas -->
                        <Label text="🔒" style="-fx-font-size: 48;">
                            <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                        </Label>

                        <!-- Titre -->
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Mot de passe oublié ?" textFill="#243447">
                                    <font><Font name="System Bold" size="26.0" /></font>
                                </Label>
                                <Label text="Contactez votre administrateur de bibliothèque."
                                       textFill="#94a3b8" wrapText="true" prefWidth="340.0">
                                    <font><Font size="13.0" /></font>
                                </Label>
                            </children>
                        </VBox>

                        <!-- Info box -->
                        <VBox spacing="12.0"
                              style="-fx-background-color: #E6F1FB; -fx-background-radius: 10;
                                     -fx-border-color: #007AFF; -fx-border-radius: 10;
                                     -fx-border-width: 0.5;">
                            <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0" /></padding>
                            <children>
                                <Label text="ℹ Comment récupérer votre compte ?"
                                       textFill="#185FA5">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                </Label>
                                <Label textFill="#243447" wrapText="true" prefWidth="300.0"
                                       text="1. Contactez le responsable de la bibliothèque EMI.">
                                    <font><Font size="12.0" /></font>
                                </Label>
                                <Label textFill="#243447" wrapText="true" prefWidth="300.0"
                                       text="2. Fournissez votre nom d'utilisateur.">
                                    <font><Font size="12.0" /></font>
                                </Label>
                                <Label textFill="#243447" wrapText="true" prefWidth="300.0"
                                       text="3. L'administrateur réinitialisera votre mot de passe.">
                                    <font><Font size="12.0" /></font>
                                </Label>
                                <Label textFill="#243447" wrapText="true" prefWidth="300.0"
                                       text="4. Connectez-vous avec votre nouveau mot de passe.">
                                    <font><Font size="12.0" /></font>
                                </Label>
                            </children>
                        </VBox>

                        <!-- Contact admin -->
                        <VBox spacing="8.0"
                              style="-fx-background-color: #F1F5F9; -fx-background-radius: 10;">
                            <padding><Insets bottom="14.0" left="16.0" right="16.0" top="14.0" /></padding>
                            <children>
                                <Label text="📧 Contact administrateur" textFill="#243447">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <Label text="admin@emi.ac.ma" textFill="#007AFF">
                                    <font><Font size="13.0" /></font>
                                </Label>
                            </children>
                        </VBox>

                        <!-- Bouton retour -->
                        <Button mnemonicParsing="false" onAction="#handleRetour"
                                prefHeight="50.0" prefWidth="340.0"
                                text="← Retour à la connexion"
                                style="-fx-background-color: #243447; -fx-text-fill: white;
                                       -fx-background-radius: 10; -fx-cursor: hand;
                                       -fx-font-weight: bold; -fx-font-size: 13;">
                            <effect>
                                <DropShadow height="20.0" radius="9.5" width="20.0"
                                            color="#24344744" offsetY="5" />
                            </effect>
                        </Button>

                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>