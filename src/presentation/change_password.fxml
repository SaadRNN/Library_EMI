<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #F8FAFC;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ChangePasswordController">
    <children>
        <HBox prefHeight="600.0" prefWidth="900.0"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- SIDEBAR -->
                <AnchorPane prefHeight="600.0" prefWidth="420.0" style="-fx-background-color: #1a252f;">
                    <children>
                        <ImageView fitHeight="600.0" fitWidth="420.0" opacity="0.4"
                                   pickOnBounds="true" preserveRatio="false">
                            <image><Image url="@library_bg.jpg" /></image>
                        </ImageView>
                        <VBox alignment="CENTER_LEFT" prefHeight="600.0" prefWidth="420.0"
                              spacing="15.0"
                              style="-fx-background-color: linear-gradient(to bottom, transparent, rgba(26, 37, 47, 0.8));">
                            <padding><Insets left="40.0" /></padding>
                            <children>
                                <Label text="EMIBook" textFill="WHITE">
                                    <font><Font name="System Bold" size="48.0" /></font>
                                    <effect><DropShadow radius="10.0" color="#00000055" /></effect>
                                </Label>
                                <Label text="MANAGEMENT SYSTEM V2.0" textFill="#007AFF">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <Line endX="100.0" stroke="WHITE" strokeWidth="2.0" opacity="0.6" />
                                <Label text="Gestion sécurisée des accès utilisateurs."
                                       textFill="#bdc3c7" wrapText="true" prefWidth="300.0">
                                    <font><Font size="14.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                        <Label text="© 2026 EMI ENGINEERING" textFill="#7f8c8d"
                               AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="40.0">
                            <font><Font size="10.0" /></font>
                        </Label>
                    </children>
                </AnchorPane>

                <!-- FORMULAIRE -->
                <VBox alignment="CENTER" prefHeight="600.0" prefWidth="480.0"
                      spacing="22.0" style="-fx-background-color: white;">
                    <padding><Insets left="70.0" right="70.0" /></padding>
                    <children>

                        <!-- Icône -->
                        <Label text="🔐" style="-fx-font-size: 48;">
                            <VBox.margin><Insets bottom="5.0" /></VBox.margin>
                        </Label>

                        <!-- Titre -->
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Réinitialiser le mot de passe" textFill="#243447">
                                    <font><Font name="System Bold" size="24.0" /></font>
                                </Label>
                                <Label fx:id="labelUsername" text="Utilisateur : —"
                                       textFill="#007AFF">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                                <Label text="Définissez un nouveau mot de passe pour cet utilisateur."
                                       textFill="#94a3b8" wrapText="true" prefWidth="340.0">
                                    <font><Font size="13.0" /></font>
                                </Label>
                            </children>
                        </VBox>

                        <!-- Nouveau mot de passe -->
                        <VBox spacing="8.0">
                            <children>
                                <Label text="Nouveau mot de passe" textFill="#64748b">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                </Label>
                                <PasswordField fx:id="newPasswordField" prefHeight="45.0"
                                               promptText="Minimum 8 caractères"
                                               style="-fx-background-color: #F1F5F9;
                                                     -fx-border-color: transparent;
                                                     -fx-background-radius: 10;
                                                     -fx-padding: 0 15 0 15;"/>
                            </children>
                        </VBox>

                        <!-- Confirmation -->
                        <VBox spacing="8.0">
                            <children>
                                <Label text="Confirmer le mot de passe" textFill="#64748b">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                </Label>
                                <PasswordField fx:id="confirmPasswordField" prefHeight="45.0"
                                               promptText="Retapez le mot de passe"
                                               style="-fx-background-color: #F1F5F9;
                                                     -fx-border-color: transparent;
                                                     -fx-background-radius: 10;
                                                     -fx-padding: 0 15 0 15;"/>
                            </children>
                        </VBox>

                        <!-- Bouton confirmer -->
                        <Button mnemonicParsing="false" onAction="#handleConfirmer"
                                prefHeight="50.0" prefWidth="340.0"
                                text="Confirmer le changement"
                                style="-fx-background-color: #007AFF; -fx-text-fill: white;
                                       -fx-background-radius: 10; -fx-cursor: hand;
                                       -fx-font-weight: bold; -fx-font-size: 13;">
                            <effect>
                                <DropShadow height="20.0" radius="9.5" width="20.0"
                                            color="#007aff44" offsetY="5" />
                            </effect>
                        </Button>

                        <!-- Bouton annuler -->
                        <Button mnemonicParsing="false" onAction="#handleAnnuler"
                                prefHeight="45.0" prefWidth="340.0"
                                text="← Retour au dashboard"
                                style="-fx-background-color: transparent; -fx-text-fill: #243447;
                                       -fx-border-color: #e2e8f0; -fx-border-radius: 10;
                                       -fx-background-radius: 10; -fx-cursor: hand;
                                       -fx-font-size: 13;"/>

                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>