<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.Line?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LoginController">
    <children>
        <HBox prefHeight="600.0" prefWidth="900.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <AnchorPane prefHeight="600.0" prefWidth="420.0" style="-fx-background-color: #1a252f;">
                    <children>
                        <ImageView fitHeight="600.0" fitWidth="420.0" opacity="0.4" pickOnBounds="true" preserveRatio="false">
                            <image>
                                <Image url="@library_bg.jpg" />
                            </image>
                        </ImageView>
                        <VBox alignment="CENTER_LEFT" prefHeight="600.0" prefWidth="420.0" spacing="15.0" style="-fx-background-color: linear-gradient(to bottom, transparent, rgba(26, 37, 47, 0.8));">
                            <padding>
                                <Insets left="40.0" />
                            </padding>
                            <children>
                                <Label text="EMIBook" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="48.0" />
                                    </font>
                                    <effect>
                                        <DropShadow radius="10.0" color="#00000055" />
                                    </effect>
                                </Label>
                                <Label text="MANAGEMENT SYSTEM V2.0" textFill="#007AFF" style="-fx-letter-spacing: 2px;">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <Line endX="100.0" stroke="WHITE" strokeWidth="2.0" opacity="0.6" />
                                <Label text="L'excellence de l'ingénierie au service de la connaissance." textFill="#bdc3c7" wrapText="true" prefWidth="300.0">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <Label layoutX="40.0" layoutY="550.0" text="© 2026 EMI ENGINEERING" textFill="#7f8c8d" AnchorPane.bottomAnchor="25.0">
                            <font>
                                <Font size="10.0" />
                            </font>
                        </Label>
                    </children>
                </AnchorPane>

                <VBox alignment="CENTER" prefHeight="600.0" prefWidth="480.0" spacing="25.0" style="-fx-background-color: white;">
                    <padding>
                        <Insets left="70.0" right="70.0" />
                    </padding>
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Connexion" textFill="#243447">
                                    <font>
                                        <Font name="System Bold" size="30.0" />
                                    </font>
                                </Label>
                                <Label text="Accédez à votre espace bibliothèque EMI." textFill="#94a3b8">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox spacing="18.0">
                            <children>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Identifiant" textFill="#64748b">
                                            <font>
                                                <Font name="System Semibold" size="13.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="usernameField" prefHeight="45.0" promptText="Ex: saad.emi" style="-fx-background-color: #F1F5F9; -fx-border-color: transparent; -fx-background-radius: 10; -fx-padding: 0 15 0 15;" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0">
                                    <children>
                                        <Label text="Mot de passe" textFill="#64748b">
                                            <font>
                                                <Font name="System Semibold" size="13.0" />
                                            </font>
                                        </Label>
                                        <PasswordField fx:id="passwordField" prefHeight="45.0" promptText="••••••••••••" style="-fx-background-color: #F1F5F9; -fx-border-color: transparent; -fx-background-radius: 10; -fx-padding: 0 15 0 15;" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <CheckBox mnemonicParsing="false" text="Rester connecté" textFill="#64748b" style="-fx-cursor: hand;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Hyperlink onAction="#handleForgotPassword" text="Oublié ?" textFill="#007AFF" style="-fx-underline: false;" />                            </children>
                        </HBox>

                        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" prefHeight="50.0" prefWidth="340.0"
                                style="-fx-background-color: #243447; -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: bold;"
                                text="Se connecter">
                            <effect>
                                <DropShadow height="20.0" radius="9.5" width="20.0" color="#24344744" offsetY="5" />
                            </effect>
                        </Button>

                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="Nouveau ici ?" textFill="#94a3b8" />
                                <Hyperlink onAction="#switchToSignUp" text="Créer un compte" textFill="#007AFF" style="-fx-font-weight: bold;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>